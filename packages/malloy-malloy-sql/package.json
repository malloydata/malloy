{
  "name": "@malloydata/malloy-sql",
  "version": "0.0.351",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/malloydata/malloy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/malloydata/malloy"
  },
  "scripts": {
    "codegen": "node ../../scripts/femto-build.js codegen",
    "lint": "eslint '**/*.ts{,x}'",
    "lint-fix": "eslint '**/*.ts{,x}' --fix",
    "test": "npm run codegen && jest --config=../../jest.config.js",
    "dev": "npm run codegen && tsc --build",
    "build": "npm run codegen && tsc --build",
    "clean": "tsc --build --clean && rm -f tsconfig.tsbuildinfo .*.digest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@malloydata/malloy": "0.0.351"
  },
  "devDependencies": {
    "peggy": "^4.2.0"
  }
}
