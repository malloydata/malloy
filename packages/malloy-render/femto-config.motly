build: {
  inputs = [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "vite.config.base.mts",
    "vite.config.esm.mts",
    "vite.config.umd.mts",
    "tsconfig.json"
  ]
  outputs = ["dist/module/index.mjs", "dist/module/index.umd.js"]
  commands = [
    "rm -rf dist/module",
    "npx vite build --outDir 'dist/module' --config vite.config.esm.mts",
    "npx vite build --outDir 'dist/module' --config vite.config.umd.mts"
  ]
}
